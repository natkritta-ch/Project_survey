generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-1.0.x", "debian-openssl-1.1.x", "debian-openssl-3.0.x", "linux-musl-openssl-3.0.x", "windows"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model attendance {
  id        String          @id @default(cuid())
  studentId String
  subjectId String?
  type      attendance_type
  status    String
  timestamp DateTime        @default(now())
  student   user            @relation(fields: [studentId], references: [id], onDelete: Cascade, map: "Attendance_studentId_fkey")
  subject   subject?        @relation(fields: [subjectId], references: [id], map: "Attendance_subjectId_fkey")

  @@index([studentId], map: "Attendance_studentId_fkey")
  @@index([subjectId], map: "Attendance_subjectId_fkey")
}

model grade {
  id        String   @id @default(cuid())
  studentId String
  subjectId String
  grade     Float
  createdAt DateTime @default(now())
  updatedAt DateTime
  student   user     @relation(fields: [studentId], references: [id], onDelete: Cascade, map: "Grade_studentId_fkey")
  subject   subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade, map: "Grade_subjectId_fkey")

  @@unique([studentId, subjectId], map: "Grade_studentId_subjectId_key")
  @@index([subjectId], map: "Grade_subjectId_fkey")
}

model schedule {
  id        String    @id @default(cuid())
  subjectId String
  dayOfWeek Int
  startTime String
  endTime   String
  deletedAt DateTime?
  subject   subject   @relation(fields: [subjectId], references: [id], onDelete: Cascade, map: "Schedule_subjectId_fkey")

  @@index([subjectId], map: "Schedule_subjectId_fkey")
}

model subject {
  id           String       @id @default(cuid())
  name         String
  code         String
  level        String       @default("-")
  group        String       @default("ก.1,2")
  room         String?
  academicYear String       @default("2569")
  term         String       @default("1")
  credit       Float        @default(3)
  teacherId    String?
  deletedAt    DateTime?
  attendance   attendance[]
  grade        grade[]
  schedule     schedule[]
  teacher      user?        @relation(fields: [teacherId], references: [id], map: "Subject_teacherId_fkey")

  @@unique([code, academicYear, term], map: "Subject_code_academicYear_term_key")
  @@index([teacherId], map: "Subject_teacherId_fkey")
}

model termConfig {
  id           String   @id @default(cuid())
  academicYear String
  term         String
  startDate    DateTime
  endDate      DateTime
  isCurrent    Boolean  @default(false)

  @@unique([academicYear, term], map: "TermConfig_academicYear_term_key")
  @@map("termconfig")
}

model user {
  id                 String       @id @default(cuid())
  name               String
  username           String       @unique(map: "User_username_key")
  password           String
  twoFactorSecret    String?
  isTwoFactorEnabled Boolean      @default(false)
  role               user_role
  faceDescriptor     String?      @db.Text
  level              String?
  canEditProfile     Boolean      @default(false)
  canSubmitGrades    Boolean      @default(false)
  nickname           String?
  phone              String?
  address            String?      @db.Text
  bloodType          String?
  gender             String?
  email              String?      @unique(map: "User_email_key")
  profilePicture     String?      @db.MediumText
  studentId          String?
  deletedAt          DateTime?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @default(now())
  attendances        attendance[]
  grades             grade[]
  subjects           subject[]
  student            user?        @relation("userTouser", fields: [studentId], references: [id], map: "User_studentId_fkey")
  students           user[]       @relation("userTouser")

  @@index([studentId], map: "User_studentId_fkey")
}

enum attendance_type {
  class
  assembly
}

enum user_role {
  HEAD
  TEACHER
  STUDENT
  PARENT
}
